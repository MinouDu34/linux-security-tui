            else:
                line_count += 1
            
            if line_count >= scroll and y < height - 2:
                stdscr.addstr(y, 4, f"Reasons: {reasons}"[:width-6], curses.color_pair(5))
                y += 1
                line_count += 1
            else:
                line_count += 1
            
            if details["exists"] and details["cmdline"] != "N/A":
                if line_count >= scroll and y < height - 2:
                    stdscr.addstr(y, 4, f"Cmd: {details['cmdline']}"[:width-6], curses.color_pair(5))
                    y += 1
                    line_count += 1
                else:
                    line_count += 1
            
            if line_count >= scroll and y < height - 2:
                y += 1
                line_count += 1
            else:
                line_count += 1
    else:
        if line_count >= scroll and y < height - 2:
            stdscr.addstr(y, 4, "Aucun processus suspect détecté", curses.color_pair(2))
            y += 1
        line_count += 1
    
    if line_count >= scroll and y < height - 2:
        y += 1
        line_count += 1
    else:
        line_count += 1
    
    # Service suggestions
    if line_count >= scroll and y < height - 2:
        stdscr.addstr(y, 2, f"Services à désactiver: {len(suggestions)}", curses.color_pair(4) | curses.A_BOLD)
        y += 1
        line_count += 1
    else:
        line_count += 1
    
    if suggestions:
        for sug in suggestions:
            if line_count >= scroll and y < height - 2:
                line = f"  [{sug['impact']}] {sug['service']}: {sug['reason']}"
                stdscr.addstr(y, 2, line[:width-4], curses.color_pair(4))
                y += 1
                line_count += 1
            else:
                line_count += 1
            
            if line_count >= scroll and y < height - 2:
                stdscr.addstr(y, 4, f"Cmd: {sug['command']}"[:width-6], curses.color_pair(5))
                y += 1
                line_count += 1
            else:
                line_count += 1
            
            if line_count >= scroll and y < height - 2:
                y += 1
                line_count += 1
            else:
                line_count += 1
    else:
        if line_count >= scroll and y < height - 2:
            stdscr.addstr(y, 4, "Aucune suggestion", curses.color_pair(2))
            y += 1
        line_count += 1
    
    return line_count

def draw_disks_tab(stdscr, data, start_y, height, width, scroll):
    y = start_y
    line_count = 0
    
    disk_info = data.get("disk_info", {})
    filesystems = disk_info.get("filesystems", [])
    block_devices = disk_info.get("block_devices", [])
    
    # Filesystems
    if line_count >= scroll and y < height - 2:
        stdscr.addstr(y, 2, f"Systèmes de fichiers: {len(filesystems)}", curses.color_pair(1) | curses.A_BOLD)
        y += 1
        line_count += 1
    else:
        line_count += 1
    
    if line_count >= scroll and y < height - 2:
        header = f"{'Device':<20} {'Type':<8} {'Size':<8} {'Used':<8} {'Avail':<8} {'Use%':<6} {'Mounted':<20}"
        stdscr.addstr(y, 2, header[:width-4], curses.color_pair(5) | curses.A_UNDERLINE)
        y += 1
        line_count += 1
    else:
        line_count += 1
    
    for fs in filesystems:
        device = fs["device"][:19]
        fstype = fs["type"][:7]
        size = fs["size"][:7]
        used = fs["used"][:7]
        avail = fs["avail"][:7]
        use_pct = fs["use_pct"]
        mounted = fs["mounted"][:19]
        
        # Color based on usage
        if use_pct >= 90:
            color = 3  # Red
        elif use_pct >= 80:
            color = 4  # Yellow
        else:
            color = 5  # White
        
        line = f"{device:<20} {fstype:<8} {size:<8} {used:<8} {avail:<8} {use_pct:<6}% {mounted:<20}"
        
        if line_count >= scroll and y < height - 2:
            stdscr.addstr(y, 2, line[:width-4], curses.color_pair(color))
            y += 1
        line_count += 1
    
    if not filesystems:
        if line_count >= scroll and y < height - 2:
            stdscr.addstr(y, 4, "Aucun système de fichiers détecté", curses.color_pair(4))
            y += 1
        line_count += 1
    
    if line_count >= scroll and y < height - 2:
        y += 1
        line_count += 1
    else:
        line_count += 1
    
    # Block devices
    if line_count >= scroll and y < height - 2:
        stdscr.addstr(y, 2, "Périphériques bloc (lsblk):", curses.color_pair(1) | curses.A_BOLD)
        y += 1
        line_count += 1
    else:
        line_count += 1
    
    for bd in block_devices:
        if line_count >= scroll and y < height - 2:
            stdscr.addstr(y, 2, bd[:width-4], curses.color_pair(5))
            y += 1
        line_count += 1
    
    if not block_devices:
        if line_count >= scroll and y < height - 2:
            stdscr.addstr(y, 4, "lsblk non disponible", curses.color_pair(4))
            y += 1
        line_count += 1
    
    return line_count

def draw_ui(stdscr, data, current_tab, scroll):
    stdscr.clear()
    height, width = stdscr.getmaxyx()
    
    y = 0
    
    # Header
    title = "=== FIREWALL AUDIT UBUNTU ==="
    stdscr.addstr(y, (width - len(title)) // 2, title, curses.color_pair(1) | curses.A_BOLD)
    y += 1
    
    # Criticité
    crit = data.get("criticality", {})
    crit_text = f"Criticité: {crit.get('level', 'N/A')} (Score: {crit.get('score', 0)})"
    stdscr.addstr(y, 2, crit_text, curses.color_pair(crit.get('color', 5)) | curses.A_BOLD)
    
    root_status = "✓ Root" if data['is_root'] else "✗ Non-root"
    root_color = curses.color_pair(2) if data['is_root'] else curses.color_pair(4)
    stdscr.addstr(y, width - len(root_status) - 2, root_status, root_color)
    y += 1
    
    # Tab bar
    draw_tab_bar(stdscr, width, current_tab)
    y += 2
    
    # Issues (only on firewall tab)
    issues = crit.get("issues", [])
    if issues and current_tab == 0:
        stdscr.addstr(y, 2, "Issues:", curses.color_pair(4) | curses.A_BOLD)
        y += 1
        for issue in issues[:3]:
            if y < height - 2:
                stdscr.addstr(y, 4, f"• {issue}"[:width-6], curses.color_pair(4))
                y += 1
        y += 1
    
    # Tab content
    start_y = y
    if current_tab == 0:
        total_lines = draw_firewall_tab(stdscr, data, start_y, height, width, scroll)
    elif current_tab == 1:
        total_lines = draw_ports_tab(stdscr, data, start_y, height, width, scroll)
    elif current_tab == 2:
        total_lines = draw_processes_tab(stdscr, data, start_y, height, width, scroll)
    elif current_tab == 3:
        total_lines = draw_monitoring_tab(stdscr, data, start_y, height, width, scroll)
    else:
        total_lines = draw_disks_tab(stdscr, data, start_y, height, width, scroll)
    
    # Footer
    footer = "Tab: Changer onglet | ↑↓: Scroll | r: Refresh | q: Quit"
    stdscr.addstr(height - 1, (width - len(footer)) // 2, footer, curses.color_pair(1))
    
    stdscr.refresh()
    return total_lines

def main(stdscr):
    curses.curs_set(0)
    stdscr.nodelay(False)
    stdscr.timeout(100)
    
    # Initialize colors
    curses.init_pair(1, curses.COLOR_CYAN, curses.COLOR_BLACK)
    curses.init_pair(2, curses.COLOR_GREEN, curses.COLOR_BLACK)
    curses.init_pair(3, curses.COLOR_RED, curses.COLOR_BLACK)
    curses.init_pair(4, curses.COLOR_YELLOW, curses.COLOR_BLACK)
    curses.init_pair(5, curses.COLOR_WHITE, curses.COLOR_BLACK)
    
    data = collect_firewall_data()
    current_tab = 0
    scroll = 0
    total_lines = 0
    
    while True:
        total_lines = draw_ui(stdscr, data, current_tab, scroll)
        
        try:
            key = stdscr.getkey()
            
            if key.lower() == 'q':
                break
            elif key.lower() == 'r':
                data = collect_firewall_data()
                scroll = 0
            elif key == '\t' or key.lower() == 't':
                current_tab = (current_tab + 1) % 5
                scroll = 0
            elif key == 'KEY_UP':
                scroll = max(0, scroll - 1)
            elif key == 'KEY_DOWN':
                height, _ = stdscr.getmaxyx()
                max_scroll = max(0, total_lines - (height - 10))
                scroll = min(max_scroll, scroll + 1)
        except:
            pass

if __name__ == "__main__":
    curses.wrapper(main)

